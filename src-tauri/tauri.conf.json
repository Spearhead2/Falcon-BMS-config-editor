{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src"
  },
  "package": {
    "productName": "Falcon BMS Config",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "dialog": { "all": true, "open": true, "save": true }
    },
    "bundle": {
      "active": true,
      "targets": ["app"],
      "identifier": "com.falconbms.config",
      "icon": ["icons/icon.ico"]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Falcon BMS Config Editor",
        "width": 1300,
        "height": 820,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  }
}
